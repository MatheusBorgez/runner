# Normaliza line endings para LF em todos os arquivos de texto
* text=auto eol=lf

# Força LF em scripts
*.sh text eol=lf
*.bash text eol=lf

# Força CRLF em arquivos Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Arquivos binários — sem conversão
*.jar binary
*.exe binary
*.png binary
*.svg binary
*.zip binary

# Go
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# Java
*.java text eol=lf
pom.xml text eol=lf
